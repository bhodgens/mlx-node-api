{
  "name": "mlx-node-api",
  "version": "0.1.0",
  "description": "OpenAI-compatible HTTP server for MLX-Node",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mlx-node-api": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "help": "node dist/index.js --help"
  },
  "keywords": [
    "mlx",
    "llm",
    "openai",
    "api"
  ],
  "license": "MIT",
  "dependencies": {
    "@mlx-node/lm": "file:../mlx-node/packages/lm",
    "@hono/node-server": "^1.14.0",
    "hono": "^4.7.5"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
